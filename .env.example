# ==============================
# Carbon Footprint Platform — Environment Variables
# Copy this file to backend/.env and fill in real values
# ==============================

# OpenAI-compatible LLM (Ollama / OpenAI / any compatible provider)
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://api.openai.com/v1   # Change to your provider's compatible endpoint
OPENAI_MODEL=gpt-4o-mini                    # Or llama3.2, gpt-4o, etc.

# OpenWeatherMap API
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_GEO_BASE_URL=https://api.openweathermap.org/geo/1.0

# OpenAQ Air Quality API
AIR_QUALITY_API_KEY=your_openaq_api_key
AIR_QUALITY_BASE_URL=https://api.openaq.org/v3

# Backend CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CarbonIQ
