# ==============================
# Carbon Footprint Platform .gitignore
# ==============================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.dmypy.json
dmypy.json
.pytest_cache/
.coverage
htmlcov/

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (NEVER commit real keys)
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker
*.log

# Datasets / large files
datasets/*.csv
datasets/*.json
