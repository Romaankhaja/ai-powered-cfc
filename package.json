{
  "name": "carboniq",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "node -e \"require('child_process').spawn(process.platform==='win32' ? '.venv\\\\Scripts\\\\python.exe' : 'python', ['-m','uvicorn','main:app','--host','0.0.0.0','--port','8000','--reload'], { cwd: 'backend', stdio: 'inherit' })\"",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "python -m compileall backend"
  }
}
